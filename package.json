{
  "name": "fello",
  "version": "0.1.0",
  "description": "ACP Client desktop app powered by Electron",
  "author": {
    "name": "Zythum",
    "email": "zythum02@gmail.com"
  },
  "type": "module",
  "main": "out/electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack:mac": "electron-vite build && electron-builder --mac",
    "pack:win": "electron-vite build && electron-builder --win",
    "pack:linux": "electron-vite build && electron-builder --linux",
    "preview": "electron-vite preview",
    "format": "oxfmt --write \"src/**/*.{ts,tsx}\"",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "build": {
    "appId": "com.zythum.fello",
    "productName": "Fello",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "icon": "icons/fello.icon",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "icons/fello.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "icons/fello.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "fuse.js": "^7.3.0",
    "mime-types": "^3.0.2",
    "node-pty": "^1.1.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.0",
    "@types/json-to-pretty-yaml": "^1.2.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-mentions": "^4.4.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "i18next": "^26.0.5",
    "json-to-pretty-yaml": "^1.2.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-diff-viewer-continued": "^4.2.0",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-mentions": "^4.4.10",
    "react-resizable-panels": "^4.10.0",
    "remark-breaks": "^4.0.0",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "zustand": "^5.0.12"
  }
}
