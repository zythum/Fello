{
  "name": "fello",
  "version": "0.1.0",
  "description": "ACP Client desktop app powered by Electrobun",
  "type": "module",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 5173",
    "build:canary": "vite build && electrobun build --env=canary",
    "format": "oxfmt --write \"src/**/*.{ts,tsx}\"",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@streamdown/code": "^1.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/react-mentions": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electrobun": "1.16.0",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-mentions": "^4.4.10",
    "react-resizable-panels": "^4.8.0",
    "shadcn": "^4.1.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.0"
  }
}
