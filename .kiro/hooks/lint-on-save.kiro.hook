{
  "enabled": true,
  "name": "Lint on Save",
  "description": "Runs oxlint on ts/tsx files after they are edited to catch lint issues early.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.ts",
      "*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx oxlint ${file}",
    "timeout": 15
  }
}